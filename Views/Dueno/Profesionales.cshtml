@model List<Usuario>
@{
    ViewData["Title"] = "Profesionales";
    var slug = ViewData["TenantSlug"] as string;
    var yoAtiendo = (bool)(ViewBag.YoAtiendo ?? false);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-people me-2"></i>Profesionales</h1>
    <a class="btn btn-primary" asp-action="ProfesionalNuevo" asp-route-slug="@slug"><i class="bi bi-person-plus me-1"></i>Nuevo</a>
</div>

<div class="card mb-4 border-0 shadow-sm" style="background:linear-gradient(135deg,#fff7ed,#ffffff 70%)">
    <div class="card-body d-flex align-items-center flex-wrap gap-3">
        <span class="ic tint-amber" style="width:48px;height:48px;border-radius:12px;display:grid;place-items:center;font-size:1.4rem"><i class="bi bi-scissors"></i></span>
        <div class="flex-grow-1">
            <h2 class="h6 mb-0">¿Tú también atiendes clientes?</h2>
            <p class="page-sub mb-0 small">Actívalo para aparecer como profesional reservable. Luego define tus <a asp-controller="Barbero" asp-action="MisServicios" asp-route-slug="@slug">servicios</a> y <a asp-controller="Barbero" asp-action="Horarios" asp-route-slug="@slug">horarios</a>.</p>
        </div>
        <form asp-action="ToggleAtiende" asp-route-slug="@slug" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="atiende" value="@((!yoAtiendo).ToString().ToLower())" />
            <button class="btn @(yoAtiendo ? "btn-outline-danger" : "btn-success")">
                @(yoAtiendo ? "Desactivar" : "Sí, yo atiendo")
            </button>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Aún no hay profesionales. Agrega el primero.</div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle bg-white shadow-sm">
            <thead class="table-light">
                <tr><th>Nombre</th><th>Cédula</th><th>Teléfono</th><th>Estado</th><th class="text-end">Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var whatsapp = PhoneHelper.WhatsAppUrl(u.Telefono);
                    <tr>
                        <td class="fw-semibold">@u.Nombre</td>
                        <td>@u.Cedula</td>
                        <td>
                            @if (whatsapp is not null)
                            {
                                <a href="@whatsapp" target="_blank" rel="noopener" class="link-success fw-semibold">
                                    <i class="bi bi-whatsapp me-1"></i>@u.Telefono
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (u.Activo) { <span class="badge bg-success">Activo</span> }
                            else { <span class="badge bg-secondary">Inactivo</span> }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Horarios" asp-route-slug="@slug" asp-route-id="@u.Id">
                                <i class="bi bi-clock"></i> Horarios
                            </a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="ProfesionalEditar" asp-route-slug="@slug" asp-route-id="@u.Id">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
