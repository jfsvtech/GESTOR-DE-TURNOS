@model GastosVm
@{
    ViewData["Title"] = "Gastos";
    var slug = ViewData["TenantSlug"] as string;
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 class="section-title mb-0">Gastos del negocio</h1>
        <p class="page-sub mb-0">Registra luz, insumos, arriendo, etc. y controla el total.</p>
    </div>
    <span class="chip"><i class="bi bi-cash-coin"></i> Total período: $@Model.Total.ToString("#,##0")</span>
</div>

<form method="get" asp-action="Gastos" asp-route-slug="@slug" class="row g-2 align-items-end mb-4">
    <div class="col-auto"><label class="form-label">Desde</label><input type="date" name="desde" value="@Model.Desde.ToString("yyyy-MM-dd")" class="form-control" /></div>
    <div class="col-auto"><label class="form-label">Hasta</label><input type="date" name="hasta" value="@Model.Hasta.ToString("yyyy-MM-dd")" class="form-control" /></div>
    <div class="col-auto"><button class="btn btn-primary">Filtrar</button></div>
</form>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card"><div class="card-body">
            <h2 class="h6 mb-3"><i class="bi bi-plus-circle me-1"></i>Nuevo gasto</h2>
            <form asp-action="GastoCrear" asp-route-slug="@slug" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Concepto</label>
                    <input name="Concepto" class="form-control" placeholder="Ej. Cuchillas, recibo de luz" required />
                </div>
                <div class="row">
                    <div class="col-7 mb-3">
                        <label class="form-label">Categoría</label>
                        <input name="Categoria" class="form-control" list="catList" placeholder="Insumos, servicios…" />
                        <datalist id="catList">
                            <option value="Insumos"></option>
                            <option value="Servicios (luz, agua)"></option>
                            <option value="Arriendo"></option>
                            <option value="Mantenimiento"></option>
                            <option value="Otros"></option>
                        </datalist>
                    </div>
                    <div class="col-5 mb-3">
                        <label class="form-label">Monto</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input name="Monto" type="text" inputmode="numeric" class="form-control js-money" required />
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Fecha</label>
                    <input name="Fecha" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <button class="btn btn-primary w-100"><i class="bi bi-check-lg me-1"></i>Registrar gasto</button>
            </form>
        </div></div>
    </div>

    <div class="col-lg-7">
        @if (Model.Gastos.Count == 0)
        {
            <div class="alert alert-info border-0 shadow-sm">No hay gastos registrados en el período.</div>
        }
        else
        {
            <div class="table-card">
                <table class="table align-middle mb-0">
                    <thead class="table-light"><tr><th>Fecha</th><th>Concepto</th><th>Categoría</th><th class="text-end">Monto</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var g in Model.Gastos)
                        {
                            <tr>
                                <td>@g.Fecha.ToString("dd/MM/yy")</td>
                                <td class="fw-semibold">@g.Concepto</td>
                                <td>@(g.Categoria ?? "—")</td>
                                <td class="text-end">$@g.Monto.ToString("#,##0")</td>
                                <td class="text-end">
                                    <form asp-action="GastoEliminar" asp-route-slug="@slug" asp-route-id="@g.Id" method="post"
                                          onsubmit="return confirm('¿Eliminar este gasto?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold"><td colspan="3" class="text-end">Total:</td><td class="text-end">$@Model.Total.ToString("#,##0")</td><td></td></tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>
