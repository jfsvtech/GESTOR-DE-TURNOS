@model List<HorarioTrabajo>
@{
    ViewData["Title"] = "Horarios";
    var slug = ViewData["TenantSlug"] as string;
    var empleado = (Usuario)ViewBag.Empleado;
    var dias = (string[])ViewBag.Dias;
    // Mapa día -> horario existente (toma el primero por día).
    var porDia = Model.GroupBy(h => h.DiaSemana).ToDictionary(g => g.Key, g => g.First());
}

<h1 class="h3 mb-1"><i class="bi bi-clock me-2"></i>Horarios</h1>
<p class="text-muted">@empleado.Nombre — marca los días y define la franja horaria. Deja vacío para días libres.</p>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Horarios" asp-route-slug="@slug" asp-route-id="@empleado.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light"><tr><th>Día</th><th>Hora inicio</th><th>Hora fin</th></tr></thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            var tiene = porDia.TryGetValue(d, out var h);
                            <tr>
                                <td class="fw-semibold">@dias[d]</td>
                                <td>
                                    <input type="hidden" name="dia" value="@d" />
                                    <input type="time" name="inicio" class="form-control"
                                           value="@(tiene ? h!.HoraInicio.ToString("HH\\:mm") : "")" />
                                </td>
                                <td>
                                    <input type="time" name="fin" class="form-control"
                                           value="@(tiene ? h!.HoraFin.ToString("HH\\:mm") : "")" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar horarios</button>
            <a class="btn btn-link" asp-action="Profesionales" asp-route-slug="@slug">Volver</a>
        </form>
    </div>
</div>
