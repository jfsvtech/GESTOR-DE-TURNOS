@model ServicioFormVm
@{
    ViewData["Title"] = Model.Id == 0 ? "Nuevo servicio" : "Editar servicio";
    var slug = ViewData["TenantSlug"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <h1 class="h4 mb-3">@ViewData["Title"]</h1>
        <div class="card shadow-sm"><div class="card-body">
            <form asp-action="ServicioGuardar" asp-route-slug="@slug" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label asp-for="DuracionMinutos" class="form-label"></label>
                        <input asp-for="DuracionMinutos" type="number" class="form-control" />
                        <span asp-validation-for="DuracionMinutos" class="text-danger small"></span>
                    </div>
                    <div class="col-6 mb-3">
                        <label asp-for="Precio" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input name="Precio" type="text" inputmode="numeric" class="form-control js-money"
                                   value="@Model.Precio.ToString("0", System.Globalization.CultureInfo.InvariantCulture)" />
                        </div>
                        <span asp-validation-for="Precio" class="text-danger small"></span>
                    </div>
                </div>
                <div class="form-check form-switch mb-3">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label">Activo</label>
                </div>
                <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a class="btn btn-link" asp-action="Servicios" asp-route-slug="@slug">Cancelar</a>
            </form>
        </div></div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
