@model BarberoFormVm
@using GeneradorTurnos.Models
@{
    ViewData["Title"] = Model.Id == 0 ? "Nuevo profesional" : "Editar profesional";
    var slug = ViewData["TenantSlug"] as string;
    var servicios = ViewBag.Servicios as List<Servicio> ?? new List<Servicio>();
    var fotoActual = ViewBag.FotoActual as string;
    var esDuenoProfesional = (bool)(ViewBag.EsDuenoProfesional ?? false);
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h1 class="h4 mb-0">@ViewData["Title"]</h1>
            @if (esDuenoProfesional)
            {
                <span class="badge text-bg-info">Dueño que atiende</span>
            }
        </div>
        <div class="card shadow-sm"><div class="card-body">
            <form asp-action="ProfesionalGuardar" asp-route-slug="@slug" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="d-flex align-items-center gap-3 mb-3">
                    @if (!string.IsNullOrEmpty(fotoActual))
                    {
                        <img src="@fotoActual" class="pro-photo" alt="Foto" />
                    }
                    else
                    {
                        <span class="avatar"><i class="bi bi-person"></i></span>
                    }
                    <div class="flex-grow-1">
                        <label class="form-label">Foto del profesional</label>
                        <input type="file" name="foto" accept="image/*" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cedula" class="form-label"></label>
                        @if (Model.Id != 0)
                        {
                            <input asp-for="Cedula" class="form-control" readonly />
                        }
                        else
                        {
                            <input asp-for="Cedula" class="form-control" />
                        }
                        <span asp-validation-for="Cedula" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefono" class="form-label"></label>
                        <input asp-for="Telefono" class="form-control" />
                        <span asp-validation-for="Telefono" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group password-field">
                        <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" type="button" data-password-toggle aria-label="Mostrar contrasena"><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-end gap-2 mb-2">
                    <div>
                        <label class="form-label mb-0">Servicios que presta</label>
                        <div class="form-text">Selecciona las tarjetas de servicios. Cada cambio queda guardado al finalizar.</div>
                    </div>
                    <span class="badge text-bg-light border">@servicios.Count servicio(s)</span>
                </div>
                <div class="service-picker-grid mb-3">
                    @foreach (var s in servicios)
                    {
                        <label class="service-pick" for="serv-@s.Id">
                            <input type="checkbox" name="ServicioIds" value="@s.Id"
                                   id="serv-@s.Id" @(Model.ServicioIds.Contains(s.Id) ? "checked" : "") />
                            <span class="service-pick-check"><i class="bi bi-check2"></i></span>
                            <span class="service-pick-body">
                                <strong>@s.Nombre</strong>
                                <small>@s.DuracionMinutos min · $@s.Precio.ToString("#,##0")</small>
                            </span>
                        </label>
                    }
                    @if (servicios.Count == 0)
                    {
                        <div class="empty-state-mini"><i class="bi bi-scissors"></i> Primero crea servicios para poder asignarlos.</div>
                    }
                </div>

                @if (esDuenoProfesional)
                {
                    <input type="hidden" asp-for="ComisionTipo" />
                    <input type="hidden" asp-for="ComisionValor" />
                    <input type="hidden" asp-for="Activo" value="true" />
                }
                else
                {
                <label class="form-label">Comisión del dueño</label>
                <div class="row g-2 mb-3">
                    <div class="col-sm-7">
                        <select asp-for="ComisionTipo" class="form-select"
                                asp-items="Html.GetEnumSelectList<ComisionTipo>()"></select>
                        <div class="form-text">Porcentaje: el dueño recibe X% de cada turno realizado. Fijo mensual: cuota fija del barbero al dueño.</div>
                    </div>
                    <div class="col-sm-5">
                        <div class="input-group">
                            <input asp-for="ComisionValor" type="text" inputmode="numeric" class="form-control js-money"
                                   value="@Model.ComisionValor.ToString("0", System.Globalization.CultureInfo.InvariantCulture)" />
                            <span class="input-group-text">% / $</span>
                        </div>
                    </div>
                </div>

                <div class="status-toggle-panel mb-3">
                    <div>
                        <strong>Estado del trabajador</strong>
                        <p class="page-sub small mb-0">Si esta inactivo, no podra iniciar sesion ni recibir reservas nuevas.</p>
                    </div>
                    <div class="status-segment" role="group" aria-label="Estado del trabajador">
                        <input class="btn-check" type="radio" name="Activo" id="proActivoSi" value="true" @(Model.Activo ? "checked" : "") />
                        <label class="seg-on" for="proActivoSi"><i class="bi bi-check-circle"></i> Activo</label>
                        <input class="btn-check" type="radio" name="Activo" id="proActivoNo" value="false" @(!Model.Activo ? "checked" : "") />
                        <label class="seg-off" for="proActivoNo"><i class="bi bi-slash-circle"></i> Inactivo</label>
                    </div>
                </div>

                }

                <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a class="btn btn-link" asp-action="Profesionales" asp-route-slug="@slug">Cancelar</a>
            </form>
        </div></div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
