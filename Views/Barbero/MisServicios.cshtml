@model List<ServicioBarbero>
@{
    ViewData["Title"] = "Mis servicios";
    var slug = ViewData["TenantSlug"] as string;
}

<h1 class="section-title mb-1">Mis servicios y precios</h1>
<p class="page-sub mb-4">Propón servicios, precio y duración. El dueño revisa y aprueba antes de que el cambio quede publicado.</p>

@if (Model.Count == 0)
{
    <div class="alert alert-info border-0 shadow-sm">El negocio aun no tiene servicios en el catalogo.</div>
}
else
{
    <form asp-action="MisServicios" asp-route-slug="@slug" method="post">
        @Html.AntiForgeryToken()
        <div class="table-card mb-3">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Ofrezco</th><th>Servicio</th><th>Base</th><th>Precio propuesto</th><th>Duracion propuesta</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="ofrecidos" value="@s.ServicioId" @(s.Ofrecido ? "checked" : "")>
                                </div>
                            </td>
                            <td class="fw-semibold">@s.Nombre</td>
                            <td class="text-muted">$@s.PrecioBase.ToString("#,##0") - @s.DuracionBase min</td>
                            <td style="max-width:160px">
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="text" inputmode="numeric" class="form-control js-money" name="precios[@s.ServicioId]"
                                           value="@(s.PrecioOverride?.ToString("0", System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                           placeholder="@s.PrecioBase.ToString("0", System.Globalization.CultureInfo.InvariantCulture)" />
                                </div>
                            </td>
                            <td style="max-width:130px">
                                <input type="number" class="form-control" name="duraciones[@s.ServicioId]"
                                       value="@(s.DuracionOverride?.ToString() ?? "")" placeholder="@s.DuracionBase" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <button class="btn btn-primary"><i class="bi bi-send-check me-1"></i>Enviar para aprobacion</button>
    </form>
}
