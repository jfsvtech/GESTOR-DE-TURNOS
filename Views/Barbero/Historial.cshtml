@model List<TurnoDetalle>
@{
    ViewData["Title"] = "Historial";
    var slug = ViewData["TenantSlug"] as string;
    var desde = (DateTime)ViewData["Desde"]!;
    var hasta = (DateTime)ViewData["Hasta"]!;
    var r = (ResumenStats)ViewBag.Resumen;
}

<h1 class="section-title mb-1">Historial de cortes</h1>
<p class="page-sub mb-4">Tus turnos y ganancias en el período.</p>

<form method="get" asp-action="Historial" asp-route-slug="@slug" class="row g-2 align-items-end mb-4">
    <div class="col-auto"><label class="form-label">Desde</label><input type="date" name="desde" value="@desde.ToString("yyyy-MM-dd")" class="form-control" /></div>
    <div class="col-auto"><label class="form-label">Hasta</label><input type="date" name="hasta" value="@hasta.ToString("yyyy-MM-dd")" class="form-control" /></div>
    <div class="col-auto"><button class="btn btn-primary">Filtrar</button></div>
</form>

<div class="row g-3 mb-4">
    <partial name="_Stat" model='("Cortes completados", r.TurnosCompletados.ToString(), "bi-check2-circle", "green")' />
    <partial name="_Stat" model='("Ganancias", "$" + r.IngresosTotales.ToString("#,##0"), "bi-cash-coin", "violet")' />
    <partial name="_Stat" model='("Ticket promedio", "$" + r.TicketPromedio.ToString("#,##0"), "bi-receipt", "blue")' />
    <partial name="_Stat" model='("Clientes", r.ClientesUnicos.ToString(), "bi-people", "amber")' />
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info border-0 shadow-sm">No hay turnos en el período.</div>
}
else
{
    <div class="table-card">
        <table class="table align-middle mb-0">
            <thead class="table-light"><tr><th>Fecha</th><th>Cliente</th><th>Servicio</th><th>Estado</th><th class="text-end">Precio</th></tr></thead>
            <tbody>
                @foreach (var t in Model.OrderByDescending(x => x.FechaHoraInicio))
                {
                    <tr>
                        <td>@t.FechaHoraInicio.ToString("dd/MM/yy HH:mm")</td>
                        <td>@t.ClienteNombre <small class="text-muted">@t.ClienteCedula</small></td>
                        <td>@t.ServicioNombre</td>
                        <td><span class="badge @t.Estado.Badge()">@t.Estado.Display()</span></td>
                        <td class="text-end fw-semibold">$@t.Precio.ToString("#,##0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
