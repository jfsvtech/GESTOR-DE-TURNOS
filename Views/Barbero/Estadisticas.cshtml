@model DashboardBarberoVm
@{
    ViewData["Title"] = "Mis estadísticas";
    var slug = ViewData["TenantSlug"] as string;
    var labels = Model.TurnosPorDia.Select(x => x.Fecha.ToString("dd/MM")).ToList();
    var ingresos = Model.TurnosPorDia.Select(x => x.Valor).ToList();
    var cantidades = Model.TurnosPorDia.Select(x => x.Cantidad).ToList();
    var servLabels = Model.ServiciosTop.Select(x => x.Etiqueta).ToList();
    var servCant = Model.ServiciosTop.Select(x => x.Cantidad).ToList();
}

<h1 class="h3 mb-3"><i class="bi bi-bar-chart me-2"></i>Mis estadísticas</h1>

<form method="get" asp-action="Estadisticas" asp-route-slug="@slug" class="row g-2 align-items-end mb-4">
    <div class="col-auto">
        <label class="form-label small">Desde</label>
        <input type="date" name="desde" value="@Model.Desde.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-auto">
        <label class="form-label small">Hasta</label>
        <input type="date" name="hasta" value="@Model.Hasta.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-auto"><button class="btn btn-primary">Filtrar</button></div>
</form>

<div class="row g-3 mb-4">
    <partial name="_Stat" model='("Cortes completados", Model.Resumen.TurnosCompletados.ToString(), "bi-check2-circle", "green")' />
    <partial name="_Stat" model='("Ingresos generados", "$" + Model.Resumen.IngresosTotales.ToString("#,##0"), "bi-cash-coin", "violet")' />
    <partial name="_Stat" model='("Ticket promedio", "$" + Model.Resumen.TicketPromedio.ToString("#,##0"), "bi-receipt", "blue")' />
    <partial name="_Stat" model='("Total turnos", Model.Resumen.TurnosTotales.ToString(), "bi-calendar3", "slate")' />
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card shadow-sm"><div class="card-body">
            <h2 class="h6">Cortes e ingresos por día</h2>
            <canvas id="chartDia" height="140"></canvas>
        </div></div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm"><div class="card-body">
            <h2 class="h6">Servicios más realizados</h2>
            <canvas id="chartServ" height="160"></canvas>
        </div></div>
    </div>
</div>

@section Scripts {
<script>
    const labels = @Json.Serialize(labels);
    new Chart(document.getElementById('chartDia'), {
        type: 'bar',
        data: { labels,
            datasets: [
                { label: 'Cortes', data: @Json.Serialize(cantidades), backgroundColor: '#0d6efd', yAxisID: 'y' },
                { label: 'Ingresos', data: @Json.Serialize(ingresos), type: 'line', borderColor: '#198754', yAxisID: 'y1', tension: .3 }
            ] },
        options: { responsive: true, scales: { y: { beginAtZero: true, position: 'left' },
            y1: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false } } } }
    });
    new Chart(document.getElementById('chartServ'), {
        type: 'doughnut',
        data: { labels: @Json.Serialize(servLabels),
            datasets: [{ data: @Json.Serialize(servCant),
                backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#6f42c1','#fd7e14'] }] }
    });
</script>
}
