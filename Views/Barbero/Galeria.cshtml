@model List<GeneradorTurnos.Models.GaleriaFoto>
@{
    ViewData["Title"] = "Mi galería";
    var slug = ViewData["TenantSlug"] as string;
}

<h1 class="section-title mb-1">Mi perfil y galería</h1>
<p class="page-sub mb-4">Sube tu foto de perfil y los trabajos que verán los clientes.</p>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100"><div class="card-body">
            <h2 class="h6 mb-3"><i class="bi bi-person-badge me-1"></i>Foto de perfil</h2>
            <form asp-action="MiFoto" asp-route-slug="@slug" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="input-group">
                    <input type="file" name="foto" accept="image/*" class="form-control" required />
                    <button class="btn btn-primary"><i class="bi bi-upload me-1"></i>Actualizar</button>
                </div>
            </form>
        </div></div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100"><div class="card-body">
            <h2 class="h6 mb-3"><i class="bi bi-images me-1"></i>Agregar trabajo</h2>
            <form asp-action="GaleriaSubir" asp-route-slug="@slug" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input type="text" name="descripcion" class="form-control" placeholder="Descripción (opcional)" /></div>
                <div class="input-group">
                    <input type="file" name="foto" accept="image/*" class="form-control" required />
                    <button class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Subir</button>
                </div>
            </form>
        </div></div>
    </div>
</div>

<h2 class="h6 text-muted mb-2">Mis trabajos</h2>
@if (Model.Count == 0)
{
    <div class="alert alert-info border-0 shadow-sm">Aún no has subido fotos de trabajos.</div>
}
else
{
    <div class="gallery-grid">
        @foreach (var g in Model)
        {
            <div class="gallery-item position-relative">
                <img src="@g.FotoUrl" alt="@(g.Descripcion ?? "Trabajo")" loading="lazy" />
                <form asp-action="GaleriaEliminar" asp-route-slug="@slug" asp-route-id="@g.Id" method="post"
                      class="position-absolute top-0 end-0 m-1" onsubmit="return confirm('¿Eliminar esta foto?');">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-danger rounded-circle" title="Eliminar"><i class="bi bi-x"></i></button>
                </form>
            </div>
        }
    </div>
}
