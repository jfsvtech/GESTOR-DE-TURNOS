@model (string Titulo, string Valor, string Icono, string Tint)

<div class="col-6 col-lg-3">
    <div class="stat d-flex align-items-center gap-3">
        <span class="ic tint-@Model.Tint"><i class="bi @Model.Icono"></i></span>
        <div>
            <div class="lbl">@Model.Titulo</div>
            <div class="val">@Model.Valor</div>
        </div>
    </div>
</div>
