@{
    var tenantNombre = ViewData["TenantNombre"] as string;
    var tenantSlug = ViewData["TenantSlug"] as string;
    var usuarioNombre = ViewData["UsuarioNombre"] as string;
    var usuarioRol = ViewData["UsuarioRol"] as string;
    string Ini(string? n) => string.IsNullOrWhiteSpace(n) ? "?" : string.Concat(n.Trim().Split(' ').Take(2).Select(p => p[0])).ToUpper();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#059669" />
    <meta name="description" content="Gestiona turnos, clientes, trabajadores y ventas desde una app instalable." />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Turnos" />
    <title>@ViewData["Title"] · @(tenantNombre ?? "Generador de Turnos")</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/icons/pwa-icon.svg" />
    <link rel="apple-touch-icon" href="/icons/pwa-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg app-nav sticky-top">
        <div class="container">
            @if (tenantSlug != null)
            {
                <a class="navbar-brand" asp-controller="Booking" asp-action="Index" asp-route-slug="@tenantSlug">
                    <span class="brand-badge"><i class="bi bi-calendar2-check"></i></span>@tenantNombre
                </a>
            }
            else
            {
                <a class="navbar-brand" href="/"><span class="brand-badge"><i class="bi bi-calendar2-check"></i></span>Turnos</a>
            }
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-1">
                    @if (tenantSlug != null)
                    {
                        @if (usuarioRol == "Barbero")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Barbero" asp-action="Hoy" asp-route-slug="@tenantSlug"><i class="bi bi-lightning-charge me-1"></i>Hoy</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Barbero" asp-action="Agenda" asp-route-slug="@tenantSlug"><i class="bi bi-calendar-week me-1"></i>Agenda</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Barbero" asp-action="Calendario" asp-route-slug="@tenantSlug"><i class="bi bi-calendar3 me-1"></i>Calendario</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Barbero" asp-action="NuevoTurno" asp-route-slug="@tenantSlug"><i class="bi bi-plus-circle me-1"></i>Nuevo turno</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Barbero" asp-action="Historial" asp-route-slug="@tenantSlug"><i class="bi bi-clock-history me-1"></i>Historial</a></li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-three-dots me-1"></i>Más</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Barbero" asp-action="Estadisticas" asp-route-slug="@tenantSlug"><i class="bi bi-graph-up me-2"></i>Estadísticas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Barbero" asp-action="MisServicios" asp-route-slug="@tenantSlug"><i class="bi bi-tags me-2"></i>Mis servicios</a></li>
                                    <li><a class="dropdown-item" asp-controller="Barbero" asp-action="Horarios" asp-route-slug="@tenantSlug"><i class="bi bi-clock me-2"></i>Mis horarios</a></li>
                                    <li><a class="dropdown-item" asp-controller="Barbero" asp-action="Galeria" asp-route-slug="@tenantSlug"><i class="bi bi-images me-2"></i>Mi galería</a></li>
                                </ul>
                            </li>
                        }
                        else if (usuarioRol == "Dueno")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Dueno" asp-action="Index" asp-route-slug="@tenantSlug"><i class="bi bi-speedometer2 me-1"></i>Panel</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Dueno" asp-action="Onboarding" asp-route-slug="@tenantSlug"><i class="bi bi-rocket-takeoff me-1"></i>Inicio guiado</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Dueno" asp-action="Profesionales" asp-route-slug="@tenantSlug"><i class="bi bi-people me-1"></i>Equipo</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Dueno" asp-action="Servicios" asp-route-slug="@tenantSlug"><i class="bi bi-tags me-1"></i>Servicios</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Dueno" asp-action="Turnos" asp-route-slug="@tenantSlug"><i class="bi bi-calendar3 me-1"></i>Turnos</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Dueno" asp-action="Gastos" asp-route-slug="@tenantSlug"><i class="bi bi-receipt me-1"></i>Gastos</a></li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-three-dots me-1"></i>Más</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Dueno" asp-action="Negocio" asp-route-slug="@tenantSlug"><i class="bi bi-shop me-2"></i>Foto del negocio</a></li>
                                    <li><a class="dropdown-item" asp-controller="Barbero" asp-action="Agenda" asp-route-slug="@tenantSlug"><i class="bi bi-calendar-week me-2"></i>Mi agenda</a></li>
                                    <li><a class="dropdown-item" asp-controller="Barbero" asp-action="Calendario" asp-route-slug="@tenantSlug"><i class="bi bi-calendar3 me-2"></i>Mi calendario</a></li>
                                    <li><a class="dropdown-item" asp-controller="Barbero" asp-action="Galeria" asp-route-slug="@tenantSlug"><i class="bi bi-images me-2"></i>Mi galería</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            @if (usuarioRol == "Cliente")
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Booking" asp-action="MisTurnos" asp-route-slug="@tenantSlug"><i class="bi bi-bookmark-check me-1"></i>Mis turnos</a></li>
                            }
                        }

                        @if (usuarioNombre != null && usuarioRol != null)
                        {
                            <li class="nav-item dropdown ms-lg-2">
                                <a class="nav-link d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                    <span class="avatar avatar-sm">@Ini(usuarioNombre)</span>
                                    <span class="d-none d-lg-inline">@usuarioNombre</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><span class="dropdown-item-text small text-muted">@usuarioNombre · @usuarioRol</span></li>
                                    @if (usuarioRol == "Barbero")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Barbero" asp-action="Bloquear" asp-route-slug="@tenantSlug"><i class="bi bi-slash-circle me-2"></i>Bloquear agenda</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Salir" asp-route-slug="@tenantSlug" method="post" class="px-3 py-1">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger w-100" type="submit">Cerrar sesión</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2"><a class="btn btn-primary btn-sm login-cta" asp-controller="Account" asp-action="Login" asp-route-slug="@tenantSlug"><i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesion</a></li>
                        }
                    }
                </ul>
                <button class="btn btn-sm btn-outline-primary ms-lg-2 theme-toggle-btn" type="button" data-theme-toggle title="Cambiar tema">
                    <i class="bi bi-moon-stars"></i>
                </button>
            </div>
        </div>
    </nav>

    <div class="app-loader" data-app-loader aria-hidden="true"><span></span></div>

    <main class="container py-4 flex-grow-1">
        @if (TempData["Ok"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-1"></i>@TempData["Ok"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="app-foot text-muted py-3">
        <div class="container small d-flex justify-content-between flex-wrap">
            <span>&copy; @DateTime.Now.Year · Generador de Turnos</span>
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-outline-primary pwa-install-btn" data-pwa-install hidden>
                    <i class="bi bi-phone"></i> Instalar app
                </button>
                <a class="text-muted" href="/privacidad">Privacidad</a>
            </div>
        </div>
    </footer>

    @if (tenantSlug != null)
    {
        <nav class="mobile-tabbar" aria-label="Navegacion principal movil">
            @if (usuarioRol == "Barbero")
            {
                <a asp-controller="Barbero" asp-action="Hoy" asp-route-slug="@tenantSlug"><i class="bi bi-lightning-charge"></i><span>Hoy</span></a>
                <a asp-controller="Barbero" asp-action="Agenda" asp-route-slug="@tenantSlug"><i class="bi bi-calendar-week"></i><span>Agenda</span></a>
                <a asp-controller="Barbero" asp-action="NuevoTurno" asp-route-slug="@tenantSlug"><i class="bi bi-plus-circle"></i><span>Nuevo</span></a>
                <a asp-controller="Barbero" asp-action="Historial" asp-route-slug="@tenantSlug"><i class="bi bi-clock-history"></i><span>Historial</span></a>
            }
            else if (usuarioRol == "Dueno")
            {
                <a asp-controller="Dueno" asp-action="Index" asp-route-slug="@tenantSlug"><i class="bi bi-speedometer2"></i><span>Panel</span></a>
                <a asp-controller="Dueno" asp-action="Profesionales" asp-route-slug="@tenantSlug"><i class="bi bi-people"></i><span>Equipo</span></a>
                <a asp-controller="Dueno" asp-action="Servicios" asp-route-slug="@tenantSlug"><i class="bi bi-tags"></i><span>Servicios</span></a>
                <a asp-controller="Dueno" asp-action="Turnos" asp-route-slug="@tenantSlug"><i class="bi bi-calendar3"></i><span>Turnos</span></a>
            }
            else
            {
                <a asp-controller="Booking" asp-action="Index" asp-route-slug="@tenantSlug"><i class="bi bi-house"></i><span>Inicio</span></a>
                <a asp-controller="Booking" asp-action="Index" asp-route-slug="@tenantSlug" asp-fragment="servicios"><i class="bi bi-calendar-plus"></i><span>Reservar</span></a>
                <a asp-controller="Booking" asp-action="MisTurnos" asp-route-slug="@tenantSlug"><i class="bi bi-bookmark-check"></i><span>Mis turnos</span></a>
                <a asp-controller="Account" asp-action="Login" asp-route-slug="@tenantSlug"><i class="bi bi-person"></i><span>Cuenta</span></a>
            }
        </nav>
        @if (usuarioRol == "Barbero")
        {
            <a class="mobile-primary-action" asp-controller="Barbero" asp-action="Hoy" asp-route-slug="@tenantSlug"><i class="bi bi-lightning-charge"></i> Mi jornada</a>
        }
        else if (usuarioRol == "Dueno")
        {
            <a class="mobile-primary-action" asp-controller="Dueno" asp-action="Index" asp-route-slug="@tenantSlug"><i class="bi bi-speedometer2"></i> Panel</a>
        }
        else
        {
            <a class="mobile-primary-action" asp-controller="Booking" asp-action="Index" asp-route-slug="@tenantSlug" asp-fragment="servicios"><i class="bi bi-calendar-plus"></i> Reservar</a>
        }
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/money.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
