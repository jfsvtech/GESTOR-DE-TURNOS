@model (string Titulo, string Valor, string Icono, string Color)

<div class="col-6 col-lg-3">
    <div class="card shadow-sm border-0 h-100">
        <div class="card-body d-flex align-items-center">
            <span class="display-6 text-@Model.Color me-3"><i class="bi @Model.Icono"></i></span>
            <div>
                <div class="text-muted small text-uppercase">@Model.Titulo</div>
                <div class="h4 mb-0 fw-bold">@Model.Valor</div>
            </div>
        </div>
    </div>
</div>
