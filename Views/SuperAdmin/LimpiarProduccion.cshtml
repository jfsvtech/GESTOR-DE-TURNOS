@model ResetProduccionVm
@{
    ViewData["Title"] = "Limpiar produccion";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <a class="small text-muted" asp-action="Index"><i class="bi bi-arrow-left"></i> Volver al SaaS</a>
        <div class="card mt-3 border-danger">
            <div class="card-body">
                <span class="chip mb-2"><i class="bi bi-shield-exclamation"></i> Accion irreversible</span>
                <h1 class="section-title h4">Limpiar datos para produccion real</h1>
                <p class="page-sub">
                    Esta accion elimina todas las empresas y sus datos asociados: trabajadores, clientes,
                    turnos, servicios, horarios, pagos, gastos, notificaciones, galeria y auditoria por empresa.
                    Los usuarios globales SuperAdmin se conservan.
                </p>

                <div class="alert alert-danger">
                    Para confirmar escribe exactamente <strong>LIMPIAR PRODUCCION</strong>.
                </div>

                <form asp-action="LimpiarProduccion" method="post" class="d-grid gap-3">
                    @Html.AntiForgeryToken()
                    <div>
                        <label asp-for="Confirmacion" class="form-label"></label>
                        <input asp-for="Confirmacion" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Confirmacion" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-danger" type="submit">
                            <i class="bi bi-trash3 me-1"></i> Limpiar produccion
                        </button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
