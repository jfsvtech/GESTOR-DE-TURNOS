@model ResetPasswordVm
@{
    ViewData["Title"] = "Nueva contrasena";
    Layout = "_Layout";
}

<div class="saas-login-shell">
    <section class="saas-login-hero">
        <span class="saas-kicker"><i class="bi bi-shield-lock"></i> Seguridad SaaS</span>
        <h1>Crea una nueva contrasena.</h1>
        <p>Usa una clave segura para proteger la administracion global.</p>
    </section>

    <section class="saas-login-panel">
        <div class="saas-auth-card">
            <h1 class="h3 fw-bold mb-1">Nueva contrasena</h1>
            <p class="page-sub mb-4">Despues podras iniciar sesion normalmente.</p>
            <form asp-action="Restablecer" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group password-field">
                        <input asp-for="Password" class="form-control form-control-lg" autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" type="button" data-password-toggle aria-label="Mostrar contrasena"><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <div class="input-group password-field">
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" type="button" data-password-toggle aria-label="Mostrar contrasena"><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary btn-lg w-100">Guardar contrasena</button>
            </form>
        </div>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
