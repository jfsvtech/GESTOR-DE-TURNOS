@model SuperAdminDashboardVm
@{
    ViewData["Title"] = "Panel SaaS";
}

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <span class="chip mb-2"><i class="bi bi-shield-lock"></i> Dueno del software</span>
        <h1 class="section-title mb-1">Resumen SaaS multiempresa</h1>
        <p class="page-sub mb-0">Control comercial, uso y ventas consolidadas de todas las empresas.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="ConfiguracionCorreo"><i class="bi bi-envelope-check me-1"></i>Correo</a>
        <a class="btn btn-primary" asp-action="Nuevo"><i class="bi bi-plus-lg me-1"></i>Nuevo negocio</a>
        <form asp-action="Salir" method="post">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-danger">Cerrar sesión</button>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="stat d-flex align-items-center gap-3"><span class="ic tint-green"><i class="bi bi-cash-coin"></i></span><div><div class="lbl">Ventas totales</div><div class="val">$@Model.VentasTotales.ToString("#,##0")</div></div></div></div>
    <div class="col-md-3"><div class="stat d-flex align-items-center gap-3"><span class="ic tint-blue"><i class="bi bi-buildings"></i></span><div><div class="lbl">Empresas activas</div><div class="val">@Model.EmpresasActivas</div></div></div></div>
    <div class="col-md-3"><div class="stat d-flex align-items-center gap-3"><span class="ic tint-violet"><i class="bi bi-people"></i></span><div><div class="lbl">Trabajadores</div><div class="val">@Model.UsuariosTotales</div></div></div></div>
    <div class="col-md-3"><div class="stat d-flex align-items-center gap-3"><span class="ic tint-amber"><i class="bi bi-calendar2-check"></i></span><div><div class="lbl">Turnos</div><div class="val">@Model.TurnosTotales</div></div></div></div>
</div>

@if (Model.Empresas.Count == 0)
{
    <div class="alert alert-info">No hay negocios registrados.</div>
}
else
{
    <div class="table-card">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Empresa</th>
                    <th>Ventas</th>
                    <th>Trabajadores</th>
                    <th>Clientes</th>
                    <th>Plan</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Empresas)
                {
                    var pct = t.MaxUsuarios == 0 ? 0 : Math.Min(100, (int)Math.Round(t.Trabajadores * 100m / t.MaxUsuarios));
                    <tr>
                        <td>
                            <div class="fw-semibold">@t.Nombre</div>
                            <a class="small" href="/@t.Slug" target="_blank">/@t.Slug</a>
                        </td>
                        <td class="fw-bold">$@t.Ventas.ToString("#,##0")</td>
                        <td style="min-width:180px">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>@t.Trabajadores de @t.MaxUsuarios</span>
                                <span>@pct%</span>
                            </div>
                            <div class="progress progress-thin"><div class="progress-bar" style="width:@pct%"></div></div>
                            <form asp-action="CambiarLimite" asp-route-id="@t.Id" method="post" class="d-flex gap-2 mt-2">
                                @Html.AntiForgeryToken()
                                <input class="form-control form-control-sm" type="number" min="1" name="maxUsuarios" value="@t.MaxUsuarios" aria-label="Limite de trabajadores" />
                                <button class="btn btn-sm btn-outline-primary" title="Guardar limite"><i class="bi bi-check-lg"></i></button>
                            </form>
                        </td>
                        <td>@t.Clientes</td>
                        <td><span class="badge bg-secondary">@t.Plan</span></td>
                        <td>
                            @if (t.Activo) { <span class="badge bg-success">Activo</span> }
                            else { <span class="badge bg-secondary">Inactivo</span> }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Empresa" asp-route-id="@t.Id">
                                <i class="bi bi-sliders me-1"></i>Gestionar
                            </a>
                            <form asp-action="CambiarEstado" asp-route-id="@t.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="activo" value="@((!t.Activo).ToString().ToLower())" />
                                <button class="btn btn-sm @(t.Activo ? "btn-outline-secondary" : "btn-outline-success")">
                                    @(t.Activo ? "Desactivar" : "Activar")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
