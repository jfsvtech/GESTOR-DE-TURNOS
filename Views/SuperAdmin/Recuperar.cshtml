@model ForgotPasswordVm
@{
    ViewData["Title"] = "Recuperar contrasena";
    Layout = "_Layout";
}

<div class="saas-login-shell">
    <section class="saas-login-hero">
        <span class="saas-kicker"><i class="bi bi-envelope-lock"></i> Acceso seguro</span>
        <h1>Recupera el acceso al panel SaaS.</h1>
        <p>Enviaremos un enlace temporal al correo de superadministrador registrado.</p>
    </section>

    <section class="saas-login-panel">
        <div class="saas-auth-card">
            <a class="small text-muted text-decoration-none" asp-action="Login"><i class="bi bi-arrow-left me-1"></i>Volver</a>
            <h1 class="h3 fw-bold mt-3 mb-1">Recuperar contrasena</h1>
            <p class="page-sub mb-4">El enlace vence en 2 horas.</p>
            <form asp-action="Recuperar" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="mb-4">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-icon">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control form-control-lg" autofocus placeholder="jfsvtech@gmail.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary btn-lg w-100"><i class="bi bi-send me-1"></i>Enviar enlace</button>
            </form>
        </div>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
