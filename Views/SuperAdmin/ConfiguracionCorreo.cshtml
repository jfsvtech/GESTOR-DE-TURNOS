@model EmailConfigStatusVm
@{
    ViewData["Title"] = "Configuracion de correo";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
    <div>
        <a class="small text-muted" asp-action="Index"><i class="bi bi-arrow-left"></i> Volver al SaaS</a>
        <h1 class="section-title mb-1">Correo transaccional</h1>
        <p class="page-sub mb-0">Estado de variables Railway para verificacion de correo. Los secretos se muestran enmascarados.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat">
            <div class="lbl">Estado</div>
            <div class="val">@(Model.Enabled ? "Activo" : "Inactivo")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat">
            <div class="lbl">Proveedor</div>
            <div class="val">@Model.Provider</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat">
            <div class="lbl">Remitente</div>
            <div class="val">@Model.From</div>
        </div>
    </div>
</div>

<div class="table-card mb-4">
    <table class="table align-middle mb-0">
        <thead>
            <tr>
                <th>Variable Railway</th>
                <th>Estado</th>
                <th>Valor</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Variables)
        {
            <tr>
                <td class="fw-semibold">@item.Name</td>
                <td>
                    @if (item.Present) { <span class="badge bg-success">Configurada</span> }
                    else { <span class="badge bg-danger">Falta</span> }
                </td>
                <td class="text-muted">@item.MaskedValue</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="alert alert-warning">
    <strong>Produccion:</strong> si Gmail API no esta completo, los usuarios quedan pendientes de verificacion y no podran ingresar.
</div>
