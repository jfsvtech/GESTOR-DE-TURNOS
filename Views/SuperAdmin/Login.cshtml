@model LoginEmailVm
@{
    ViewData["Title"] = "Acceso administrador";
    Layout = "_Layout";
}

<div class="saas-login-shell">
    <section class="saas-login-hero">
        <span class="saas-kicker"><i class="bi bi-shield-check"></i> SaaS Control</span>
        <h1>Administra empresas sin perder control.</h1>
        <p>Gestiona negocios, limites de trabajadores, suscripciones, pagos y seguridad desde un solo panel central.</p>
        <div class="saas-login-proof">
            <span><i class="bi bi-buildings"></i><strong>Multiempresa</strong><small>Tenants aislados</small></span>
            <span><i class="bi bi-credit-card"></i><strong>Suscripciones</strong><small>Estado y pagos</small></span>
            <span><i class="bi bi-activity"></i><strong>Auditoria</strong><small>Cambios trazables</small></span>
        </div>
    </section>

    <section class="saas-login-panel">
        <div class="saas-auth-card">
            <a class="small text-muted text-decoration-none" href="/"><i class="bi bi-arrow-left me-1"></i>Volver</a>
            <div class="d-flex align-items-center gap-2 mt-3 mb-1">
                <span class="saas-auth-icon"><i class="bi bi-lock"></i></span>
                <div>
                    <h1 class="h3 mb-0">Administrador SaaS</h1>
                    <p class="page-sub mb-0">Acceso exclusivo del dueno del software.</p>
                </div>
            </div>
            <form asp-action="Login" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-icon">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control form-control-lg" autofocus placeholder="jfsvtech@gmail.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-icon password-field">
                        <i class="bi bi-key"></i>
                        <input asp-for="Password" class="form-control form-control-lg" />
                        <button class="password-toggle" type="button" data-password-toggle aria-label="Mostrar contrasena"><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary btn-lg w-100"><i class="bi bi-box-arrow-in-right me-1"></i>Entrar al panel</button>
            </form>
            <div class="d-flex justify-content-end mt-3">
                <a asp-action="Recuperar" class="small fw-semibold">Olvidaste tu contrasena?</a>
            </div>
        </div>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
