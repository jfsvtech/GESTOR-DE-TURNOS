@model SuperAdminEmpresaDetalleVm
@{
    ViewData["Title"] = "Empresa";
    var e = Model.Empresa;
    var dias = e.SuscripcionVencimiento is null ? (int?)null : (e.SuscripcionVencimiento.Value.Date - DateTime.Today).Days;
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
    <div>
        <a class="small text-muted" asp-action="Index"><i class="bi bi-arrow-left"></i> Volver al SaaS</a>
        <h1 class="section-title mb-1">@e.Nombre</h1>
        <p class="page-sub mb-0">/@e.Slug · plan @e.Plan · @e.EstadoSuscripcion</p>
    </div>
    <a class="btn btn-outline-primary" href="/@e.Slug" target="_blank"><i class="bi bi-box-arrow-up-right me-1"></i>Ver negocio</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-4"><div class="stat"><div class="lbl">Estado empresa</div><div class="val">@(e.Activo ? "Activa" : "Suspendida")</div></div></div>
    <div class="col-lg-4"><div class="stat"><div class="lbl">Vencimiento</div><div class="val">@(e.SuscripcionVencimiento?.ToString("dd/MM/yyyy") ?? "Sin fecha")</div></div></div>
    <div class="col-lg-4"><div class="stat"><div class="lbl">Alerta pago</div><div class="val">@(dias is null ? "Sin fecha" : dias < 0 ? "Vencida" : $"{dias} dias")</div></div></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-5">
        <div class="card h-100"><div class="card-body">
            <h2 class="h6 mb-3"><i class="bi bi-credit-card me-1"></i>Suscripcion</h2>
            <form asp-action="GuardarSuscripcion" asp-route-id="@e.Id" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TenantId" value="@e.Id" />
                <div class="col-md-6">
                    <label class="form-label">Plan</label>
                    <select name="Plan" class="form-select">
                        <option selected="@(e.Plan == "Basico")">Basico</option>
                        <option selected="@(e.Plan == "Pro")">Pro</option>
                        <option selected="@(e.Plan == "Premium")">Premium</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Estado</label>
                    <select name="EstadoSuscripcion" class="form-select">
                        <option selected="@(e.EstadoSuscripcion == "Activo")">Activo</option>
                        <option selected="@(e.EstadoSuscripcion == "Suspendido")">Suspendido</option>
                        <option selected="@(e.EstadoSuscripcion == "Vencido")">Vencido</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Inicio</label>
                    <input type="date" name="SuscripcionInicio" value="@e.SuscripcionInicio?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Vencimiento</label>
                    <input type="date" name="SuscripcionVencimiento" value="@e.SuscripcionVencimiento?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Recordar dias antes</label>
                    <input type="number" min="1" max="60" name="RecordatorioPagoDias" value="@e.RecordatorioPagoDias" class="form-control" />
                </div>
                <div class="col-12"><button class="btn btn-primary"><i class="bi bi-check2 me-1"></i>Guardar suscripcion</button></div>
            </form>
        </div></div>
    </div>
    <div class="col-lg-7">
        <div class="card h-100"><div class="card-body">
            <h2 class="h6 mb-3"><i class="bi bi-receipt me-1"></i>Registrar pago</h2>
            <form asp-action="RegistrarPago" asp-route-id="@e.Id" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-4"><label class="form-label">Monto</label><input name="Monto" type="text" inputmode="numeric" class="form-control js-money" /></div>
                <div class="col-md-4"><label class="form-label">Desde</label><input name="PeriodoInicio" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-md-4"><label class="form-label">Hasta</label><input name="PeriodoFin" type="date" value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" class="form-control" /></div>
                <div class="col-md-4"><label class="form-label">Metodo</label><input name="Metodo" class="form-control" placeholder="Transferencia" /></div>
                <div class="col-md-4"><label class="form-label">Referencia</label><input name="Referencia" class="form-control" /></div>
                <div class="col-md-4"><label class="form-label">Nota</label><input name="Nota" class="form-control" /></div>
                <div class="col-12"><button class="btn btn-success"><i class="bi bi-plus-circle me-1"></i>Registrar pago</button></div>
            </form>
        </div></div>
    </div>
</div>

<div class="card mb-4"><div class="card-body">
    <h2 class="h6 mb-3"><i class="bi bi-people me-1"></i>Usuarios internos</h2>
    <form asp-action="CrearUsuario" asp-route-id="@e.Id" method="post" class="row g-2 align-items-end mb-3">
        @Html.AntiForgeryToken()
        <div class="col-md-2"><label class="form-label">Nombre</label><input name="Nombre" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Email</label><input name="Email" type="email" class="form-control" /></div>
        <div class="col-md-2"><label class="form-label">Telefono</label><input name="Telefono" class="form-control" placeholder="3001234567" /></div>
        <div class="col-md-2"><label class="form-label">Rol</label><select name="Rol" class="form-select"><option value="2">Dueno</option><option value="3">Empleado</option></select></div>
        <div class="col-md-2"><label class="form-label">Password</label><input name="Password" class="form-control" placeholder="Auto si vacio" /></div>
        <div class="col-md-1"><button class="btn btn-primary w-100">Crear</button></div>
    </form>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Usuario</th><th>Correo</th><th>Telefono</th><th>Rol</th><th>Estado</th><th>Correo</th><th class="text-end">Acciones</th></tr></thead>
            <tbody>
            @foreach (var u in Model.Usuarios.Where(x => x.Rol != Rol.Cliente))
            {
                <tr>
                    <td class="fw-semibold">@u.Nombre</td>
                    <td>@u.Email</td>
                    <td>
                        @{
                            var wa = PhoneHelper.WhatsAppUrl(u.Telefono);
                        }
                        @if (wa is not null)
                        {
                            <a href="@wa" target="_blank" rel="noopener" class="link-success fw-semibold">
                                <i class="bi bi-whatsapp me-1"></i>@u.Telefono
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <form asp-action="ActualizarUsuario" asp-route-tenantId="@e.Id" asp-route-userId="@u.Id" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <select name="rol" class="form-select form-select-sm" style="max-width:140px">
                                <option value="2" selected="@(u.Rol == Rol.Dueno)">Dueno</option>
                                <option value="3" selected="@(u.Rol == Rol.Barbero)">Empleado</option>
                            </select>
                            <input type="hidden" name="activo" value="@u.Activo.ToString().ToLower()" />
                            <button class="btn btn-sm btn-outline-primary">Guardar</button>
                        </form>
                    </td>
                    <td>@(u.Activo ? "Activo" : "Inactivo")</td>
                    <td>
                        @if (u.EmailVerificado) { <span class="badge bg-success">Verificado</span> }
                        else { <span class="badge bg-warning text-dark">Pendiente</span> }
                    </td>
                    <td class="text-end">
                        <form asp-action="ActualizarUsuario" asp-route-tenantId="@e.Id" asp-route-userId="@u.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="rol" value="@((int)u.Rol)" />
                            <input type="hidden" name="activo" value="@((!u.Activo).ToString().ToLower())" />
                            <button class="btn btn-sm btn-outline-secondary">@(u.Activo ? "Desactivar" : "Activar")</button>
                        </form>
                        <form asp-action="EliminarUsuario" asp-route-tenantId="@e.Id" asp-route-userId="@u.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div></div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100"><div class="card-body">
            <h2 class="h6 mb-3">Historial de pagos</h2>
            @foreach (var p in Model.Pagos)
            {
                <div class="d-flex justify-content-between border-bottom py-2 small">
                    <span>@p.FechaPago.ToString("dd/MM/yyyy") · @p.PeriodoInicio.ToString("dd/MM") - @p.PeriodoFin.ToString("dd/MM")</span>
                    <strong>$@p.Monto.ToString("#,##0")</strong>
                </div>
            }
            @if (!Model.Pagos.Any()) { <p class="page-sub">Sin pagos registrados.</p> }
        </div></div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100"><div class="card-body">
            <h2 class="h6 mb-3">Auditoria reciente</h2>
            @foreach (var a in Model.Auditoria)
            {
                <div class="border-bottom py-2 small">
                    <div class="d-flex justify-content-between gap-2"><strong>@a.Accion</strong><span class="text-muted">@a.FechaCreacion.ToString("dd/MM HH:mm")</span></div>
                    <div class="text-muted">@a.ActorNombre · @a.Entidad @a.EntidadId</div>
                    @if (!string.IsNullOrWhiteSpace(a.Detalle)) { <div>@a.Detalle</div> }
                </div>
            }
            @if (!Model.Auditoria.Any()) { <p class="page-sub">Sin movimientos auditados.</p> }
        </div></div>
    </div>
</div>
