@model ReservarViewModel
@{
    ViewData["Title"] = "Reservar turno";
    var slug = ViewData["TenantSlug"] as string;
    var rol = ViewData["UsuarioRol"] as string;
    var esCliente = rol == "Cliente";
    var slotsUrl = Url.Action("Slots", "Booking", new { slug });
}

<div class="booking-app-shell client-booking">
    <div class="booking-app-head">
        <div>
            <span class="booking-kicker"><i class="bi bi-calendar2-check"></i> Reserva online</span>
            <h1>Reserva con @Model.EmpleadoNombre</h1>
            <p>Elige servicio, fecha y hora. Rapido, claro y sin salir del flujo.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-slug="@slug"><i class="bi bi-arrow-left me-1"></i>Servicios</a>
    </div>

    <form asp-action="Confirmar" asp-route-slug="@slug" method="post" id="clientBookingForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="empleadoId" value="@Model.EmpleadoId" />
        <input type="hidden" name="servicioId" id="ServicioId" value="@Model.ServicioId" />
        <input type="hidden" name="inicio" id="Inicio" />
        <input type="hidden" name="notas" id="Notas" />

        <div class="booking-progress">
            <span class="active" data-step-dot="1">1 Servicio</span>
            <span data-step-dot="2">2 Fecha</span>
            <span data-step-dot="3">3 Hora</span>
            <span data-step-dot="4">4 Confirmar</span>
        </div>

        <section class="booking-step-card" data-step="1">
            <div class="booking-step-title">
                <h2>Servicio</h2>
                <p>Selecciona lo que quieres reservar.</p>
            </div>
            <div class="booking-choice-list compact">
                @foreach (var s in Model.Servicios)
                {
                    <button type="button" class="booking-service-option @(s.Id == Model.ServicioId ? "active" : "")"
                            data-service-id="@s.Id" data-service-name="@s.Nombre"
                            data-duration="@s.DuracionMinutos" data-price="@s.Precio.ToString("0", System.Globalization.CultureInfo.InvariantCulture)">
                        <span class="service-edit-icon"><i class="bi bi-scissors"></i></span>
                        <span>
                            <strong>@s.Nombre</strong>
                            <small>$@s.Precio.ToString("#,##0") - @s.DuracionMinutos min</small>
                        </span>
                        <i class="bi bi-check2"></i>
                    </button>
                }
            </div>
        </section>

        <section class="booking-step-card" data-step="2">
            <div class="booking-step-title">
                <h2>Fecha</h2>
                <p>Vuelve a hoy o salta rapido a los proximos dias.</p>
            </div>
            <input id="Fecha" type="date" class="form-control booking-date-input" value="@Model.Fecha.ToString("yyyy-MM-dd")"
                   min="@Model.Fecha.ToString("yyyy-MM-dd")" />
            <div class="booking-date-actions">
                <button type="button" class="btn btn-sm btn-outline-primary" id="todayBtn"><i class="bi bi-house-door me-1"></i>Hoy</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-day-jump="1">Manana</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-day-jump="2">+2 dias</button>
            </div>
            <div class="quick-date-strip" id="quickDates"></div>
        </section>

        <section class="booking-step-card" data-step="3">
            <div class="booking-step-title">
                <h2>Hora</h2>
                <p id="slotHint">Horarios disponibles para el servicio seleccionado.</p>
            </div>
            <div id="nextSlotSummary" class="slot-summary"></div>
            <div class="slot-filter booking-slot-filter" aria-label="Filtrar horarios">
                <button type="button" class="slot-filter-btn active" data-slot-filter="all">Todos</button>
                <button type="button" class="slot-filter-btn" data-slot-filter="morning"><i class="bi bi-sunrise"></i> Manana</button>
                <button type="button" class="slot-filter-btn" data-slot-filter="afternoon"><i class="bi bi-sun"></i> Tarde</button>
                <button type="button" class="slot-filter-btn" data-slot-filter="night"><i class="bi bi-moon"></i> Noche</button>
            </div>
            <div id="clientSlots" class="booking-slot-grid"><div class="text-muted">Cargando horarios...</div></div>
        </section>

        <section class="booking-step-card is-muted" data-step="4">
            <div class="booking-step-title">
                <h2>Confirmacion</h2>
                <p>Revisa el resumen y confirma tu turno.</p>
            </div>

            @if (!esCliente)
            {
                <div class="login-required-card">
                    <i class="bi bi-person-lock"></i>
                    <div>
                        <strong>Confirma con tu cuenta</strong>
                        <small>Al confirmar te pediremos iniciar sesion o crear cuenta. Conservaremos este turno seleccionado.</small>
                    </div>
                </div>
            }

            <div class="booking-final-bar">
                <strong id="clientSummary">Selecciona una hora</strong>
                <button class="btn btn-primary btn-lg" type="submit" id="clientSubmit" disabled>
                    <i class="bi bi-check2-circle me-1"></i>@(esCliente ? "Confirmar turno" : "Continuar y confirmar")
                </button>
            </div>
        </section>
    </form>
</div>

@section Scripts {
<script>
    (function () {
        const slotsUrl = '@slotsUrl';
        const empleadoId = @Model.EmpleadoId;
        const serviceInput = document.getElementById('ServicioId');
        const startInput = document.getElementById('Inicio');
        const dateInput = document.getElementById('Fecha');
        const slots = document.getElementById('clientSlots');
        const nextSlotSummary = document.getElementById('nextSlotSummary');
        const hint = document.getElementById('slotHint');
        const summary = document.getElementById('clientSummary');
        const submit = document.getElementById('clientSubmit');
        const todayIso = dateInput.min || dateInput.value;
        let selectedService = null;
        let allSlots = [];
        let activeFilter = 'all';

        function selectedServiceButton() {
            return document.querySelector(`.booking-service-option[data-service-id="${serviceInput.value}"]`) || document.querySelector('.booking-service-option');
        }

        function setProgress(step) {
            document.querySelectorAll('[data-step-dot]').forEach(x => x.classList.toggle('active', Number(x.dataset.stepDot) <= step));
            document.querySelectorAll('[data-step]').forEach(x => x.classList.toggle('is-muted', Number(x.dataset.step) > step));
        }

        function readService(btn) {
            selectedService = { id: btn.dataset.serviceId, name: btn.dataset.serviceName, duration: btn.dataset.duration };
            serviceInput.value = selectedService.id;
            document.querySelectorAll('.booking-service-option').forEach(x => x.classList.toggle('active', x === btn));
        }

        function buildDates() {
            const wrap = document.getElementById('quickDates');
            const base = new Date(todayIso + 'T00:00:00');
            wrap.innerHTML = '';
            for (let i = 0; i < 10; i++) {
                const d = new Date(base);
                d.setDate(base.getDate() + i);
                const iso = d.toISOString().slice(0, 10);
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'quick-date-chip' + (iso === dateInput.value ? ' active' : '');
                btn.innerHTML = `<strong>${d.toLocaleDateString('es-CO', { weekday: 'short' })}</strong><span>${d.getDate()}</span>`;
                btn.onclick = () => { dateInput.value = iso; buildDates(); loadSlots(); };
                wrap.appendChild(btn);
            }
        }

        function slotGroup(hora) {
            const h = Number(hora.split(':')[0]);
            if (h < 12) return 'morning';
            if (h < 18) return 'afternoon';
            return 'night';
        }

        function chooseSlot(s, btn) {
            startInput.value = s.inicio;
            document.querySelectorAll('.booking-slot-btn').forEach(x => x.classList.remove('active'));
            if (btn) btn.classList.add('active');
            summary.textContent = `${selectedService.name} - ${dateInput.value} - ${s.hora}`;
            submit.disabled = false;
            setProgress(4);
            document.querySelector('[data-step="4"]').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function renderSlots() {
            startInput.value = '';
            submit.disabled = true;
            slots.innerHTML = '';
            nextSlotSummary.innerHTML = '';

            if (!allSlots.length) {
                slots.innerHTML = '<div class="slot-empty">No hay horarios disponibles para esta fecha.</div>';
                return;
            }

            const next = allSlots[0];
            nextSlotSummary.innerHTML = `
                <button type="button" class="recommended-slot-card compact" id="nextSlotBtn">
                    <span class="recommended-badge"><i class="bi bi-stars"></i> Proximo disponible</span>
                    <strong>${next.hora}</strong>
                    <small>${selectedService.name} - ${selectedService.duration} min</small>
                </button>`;
            document.getElementById('nextSlotBtn').onclick = () => {
                const btn = Array.from(document.querySelectorAll('.booking-slot-btn')).find(x => x.dataset.inicio === next.inicio);
                chooseSlot(next, btn);
            };

            const visible = allSlots.filter(s => activeFilter === 'all' || slotGroup(s.hora) === activeFilter);
            if (!visible.length) {
                slots.innerHTML = '<div class="slot-empty">No hay horarios en este rango. Prueba otro filtro.</div>';
                return;
            }

            visible.forEach(s => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'booking-slot-btn' + (s.inicio === next.inicio ? ' recommended' : '');
                btn.dataset.inicio = s.inicio;
                btn.innerHTML = s.inicio === next.inicio ? `<span>${s.hora}</span><small>Mas cercano</small>` : `<span>${s.hora}</span>`;
                btn.onclick = () => chooseSlot(s, btn);
                slots.appendChild(btn);
            });
        }

        async function loadSlots() {
            startInput.value = '';
            submit.disabled = true;
            hint.textContent = `${selectedService.name} - ${selectedService.duration} min`;
            slots.innerHTML = '<div class="text-muted">Cargando horarios...</div>';
            nextSlotSummary.innerHTML = '';
            const res = await fetch(`${slotsUrl}?empleadoId=${empleadoId}&servicioId=${selectedService.id}&fecha=${dateInput.value}`);
            allSlots = (await res.json()).sort((a, b) => a.hora.localeCompare(b.hora));
            renderSlots();
            setProgress(3);
        }

        document.querySelectorAll('.booking-service-option').forEach(btn => btn.addEventListener('click', () => {
            readService(btn);
            setProgress(2);
            loadSlots();
            document.querySelector('[data-step="2"]').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }));

        dateInput.addEventListener('change', () => { buildDates(); loadSlots(); });
        document.getElementById('todayBtn').addEventListener('click', () => { dateInput.value = todayIso; buildDates(); loadSlots(); });
        document.querySelectorAll('[data-day-jump]').forEach(btn => btn.addEventListener('click', () => {
            const d = new Date(todayIso + 'T00:00:00');
            d.setDate(d.getDate() + Number(btn.dataset.dayJump));
            dateInput.value = d.toISOString().slice(0, 10);
            buildDates();
            loadSlots();
        }));
        document.querySelectorAll('[data-slot-filter]').forEach(btn => btn.addEventListener('click', () => {
            activeFilter = btn.dataset.slotFilter;
            document.querySelectorAll('[data-slot-filter]').forEach(x => x.classList.toggle('active', x === btn));
            renderSlots();
        }));

        readService(selectedServiceButton());
        buildDates();
        setProgress(2);
        loadSlots();
    })();
</script>
}
