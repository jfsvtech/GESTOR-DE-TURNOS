@model List<Tenant>
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Inicio";
    var baseDomain = (Configuration["App:BaseDomain"] ?? "").Trim().Trim('.');
    string Ini(string n) => string.Concat(n.Trim().Split(' ').Take(2).Select(p => p[0])).ToUpper();
}

<div class="hero mb-4">
    <div class="col-lg-8 position-relative">
        <span class="chip bg-white mb-3" style="color:#6d28d9"><i class="bi bi-stars"></i> Plataforma de reservas</span>
        <h1 class="display-5 fw-bold mb-2">Agenda turnos sin filas, sin llamadas</h1>
        <p class="fs-5 opacity-75">Barberías, salones y más. Elige tu profesional, mira su disponibilidad real y reserva en segundos.</p>
        <a class="btn btn-light btn-lg mt-2 fw-bold" href="#negocios"><i class="bi bi-arrow-down-circle me-1"></i>Ver negocios</a>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-3" id="negocios">
    <h2 class="section-title">Negocios disponibles</h2>
    <a class="btn btn-outline-primary btn-sm" href="/super/login"><i class="bi bi-shield-lock me-1"></i>Admin SaaS</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info border-0 shadow-sm">Aún no hay negocios registrados.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var t in Model)
        {
            var negocioUrl = string.IsNullOrWhiteSpace(baseDomain)
                ? Url.Action("Index", "Booking", new { slug = t.Slug })
                : $"https://{t.Slug}.{baseDomain}";
            <div class="col">
                <a class="text-decoration-none" href="@negocioUrl">
                    <div class="card hover-lift h-100">
                        <div class="card-body d-flex align-items-center gap-3">
                            <span class="avatar">@Ini(t.Nombre)</span>
                            <div>
                                <h5 class="mb-0 text-dark">@t.Nombre</h5>
                                <span class="chip mt-1">@t.Plan</span>
                            </div>
                            <i class="bi bi-chevron-right ms-auto text-muted"></i>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
