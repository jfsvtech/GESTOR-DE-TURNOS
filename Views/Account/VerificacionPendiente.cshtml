@{
    ViewData["Title"] = "Verifica tu correo";
    Layout = "_AuthLayout";
    var slug = ViewData["TenantSlug"] as string;
    var email = TempData["PendingEmail"] as string;
    var verifyLink = TempData["VerifyLink"] as string;
}

<div class="auth-form" style="min-height:calc(100vh - 70px)">
    <div class="auth-card text-center">
        <div class="display-4 text-violet mb-2" style="color:#6d28d9"><i class="bi bi-envelope-check"></i></div>
        <h2 class="h3 fw-bold">Revisa tu correo</h2>
        <p class="page-sub">
            Te enviamos un enlace de verificación@(string.IsNullOrEmpty(email) ? "" : $" a {email}").
            Haz clic en él para activar tu cuenta.
        </p>

        @if (!string.IsNullOrEmpty(verifyLink))
        {
            <div class="alert alert-warning border-0 text-start small mt-3">
                <strong>Modo desarrollo (sin correo configurado):</strong> usa este enlace para verificar tu cuenta.
                <div class="d-grid mt-2">
                    <a class="btn btn-primary" href="@verifyLink">Verificar mi correo ahora</a>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(email))
        {
            <form asp-action="Reenviar" asp-route-slug="@slug" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@email" />
                <button class="btn btn-outline-primary btn-sm">Reenviar correo</button>
            </form>
        }

        <div class="mt-4">
            <a class="small text-muted" asp-action="Login" asp-route-slug="@slug">Volver a iniciar sesión</a>
        </div>
    </div>
</div>
