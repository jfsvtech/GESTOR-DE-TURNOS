@model LoginEmailVm
@{
    ViewData["Title"] = "Acceso";
    Layout = "_AuthLayout";
    var slug = ViewData["TenantSlug"] as string;
    var nombre = ViewData["TenantNombre"] as string;
    var foto = ViewData["TenantFotoUrl"] as string;
    var bg = string.IsNullOrEmpty(foto)
        ? "linear-gradient(120deg,rgba(5,12,22,.9),rgba(15,118,110,.78)),url('https://images.unsplash.com/photo-1621605815971-fbc98d665033?auto=format&fit=crop&w=1600&q=85') center/cover"
        : $"linear-gradient(120deg,rgba(5,12,22,.88),rgba(15,118,110,.72)),url('{foto}') center/cover";
}

<div class="login-experience">
    <section class="login-brand" style="background:@bg">
        <div class="login-brand-content">
            <span class="eyebrow"><i class="bi bi-calendar2-check"></i> @nombre</span>
            <h1>Gestiona tu barberia sin perder turnos.</h1>
            <p>Reservas en tiempo real, historial de clientes, ingresos por trabajador y control del negocio desde un solo acceso.</p>
            <div class="login-value-grid">
                <span><i class="bi bi-calendar2-check"></i><strong>Reservas</strong><small>Agenda siempre actualizada</small></span>
                <span><i class="bi bi-person-vcard"></i><strong>Clientes</strong><small>Historial y recurrencia</small></span>
                <span><i class="bi bi-cash-stack"></i><strong>Ingresos</strong><small>Ventas por barbero</small></span>
                <span><i class="bi bi-bell"></i><strong>Alertas</strong><small>Cambios notificados</small></span>
            </div>
        </div>
    </section>

    <section class="login-panel">
        <div class="auth-card">
            <a class="small text-muted d-inline-flex align-items-center gap-1 mb-3" asp-controller="Booking" asp-action="Index" asp-route-slug="@slug">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
            <h2 class="h3 fw-bold mb-1">Entrar con correo</h2>
            <p class="page-sub mb-4">El perfil se detecta automaticamente despues de iniciar sesion.</p>

            <form asp-action="Login" asp-route-slug="@slug" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-icon"><i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control form-control-lg" autofocus placeholder="correo@ejemplo.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-icon"><i class="bi bi-lock"></i>
                        <input asp-for="Password" class="form-control form-control-lg" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100">Entrar</button>
            </form>

            <div class="login-register">
                <span>Primera vez como cliente?</span>
                <a asp-action="Registro" asp-route-slug="@slug" class="fw-semibold">Crear cuenta</a>
            </div>
        </div>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
