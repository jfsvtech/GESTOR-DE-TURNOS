@model ForgotPasswordVm
@{
    ViewData["Title"] = "Recuperar contrasena";
    Layout = "_AuthLayout";
    var slug = ViewData["TenantSlug"] as string;
}

<div class="auth-wrap">
    <div class="auth-side">
        <div>
            <span class="chip bg-white mb-3" style="color:#059669">Acceso seguro</span>
            <h1 class="display-6 fw-bold">Recupera tu acceso.</h1>
            <p class="fs-5 opacity-75 mt-2">Te enviaremos un enlace temporal al correo registrado.</p>
        </div>
    </div>
    <div class="auth-form">
        <div class="auth-card">
            <a class="small text-muted" asp-action="Login" asp-route-slug="@slug"><i class="bi bi-arrow-left"></i> Volver</a>
            <h2 class="h3 fw-bold mt-3 mb-1">Recuperar contrasena</h2>
            <p class="page-sub mb-4">El enlace vence en 2 horas.</p>
            <form asp-action="Recuperar" asp-route-slug="@slug" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-icon"><i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control form-control-lg" autofocus placeholder="correo@ejemplo.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary btn-lg w-100">Enviar enlace</button>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
