@model ResetPasswordVm
@{
    ViewData["Title"] = "Nueva contrasena";
    Layout = "_AuthLayout";
    var slug = ViewData["TenantSlug"] as string;
}

<div class="auth-wrap">
    <div class="auth-side">
        <div>
            <span class="chip bg-white mb-3" style="color:#059669">Acceso seguro</span>
            <h1 class="display-6 fw-bold">Crea una nueva contrasena.</h1>
            <p class="fs-5 opacity-75 mt-2">Usa una clave segura y no la compartas.</p>
        </div>
    </div>
    <div class="auth-form">
        <div class="auth-card">
            <h2 class="h3 fw-bold mb-1">Nueva contrasena</h2>
            <p class="page-sub mb-4">Despues podras iniciar sesion normalmente.</p>
            <form asp-action="Restablecer" asp-route-slug="@slug" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group password-field">
                        <input asp-for="Password" class="form-control form-control-lg" autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" type="button" data-password-toggle><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <div class="input-group password-field">
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" type="button" data-password-toggle><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary btn-lg w-100">Guardar contrasena</button>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
